# Used by app/api/contact (server only — do not use NEXT_PUBLIC_ for the API key)
NEXT_RESEND_API_KEY=
NEXT_CONTACT_EMAIL_TO=

# Optional (legacy names still work: RESEND_API_KEY, CONTACT_TO_EMAIL)
# Optional sender after domain verify on Resend:
# NEXT_CONTACT_FROM_EMAIL=Nedim Zec <hello@yourdomain.com>
